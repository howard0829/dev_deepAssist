# ──────────────────────────────────────────────────────────────
# DeepAssist 서버 환경변수 (샘플)   —  cp .env.sample .env
# vLLM·LiteLLM은 이 리포 밖에서 별도로 실행한다. start.sh는 DeepAssist만 기동.
# ──────────────────────────────────────────────────────────────

# ── DeepAssist 서버 ──
DEEPASSIST_PORT=8000
DEEPASSIST_HOST=0.0.0.0

# ── 외부 LiteLLM 접속 (Agent SDK → LiteLLM) ──
# 따로 실행한 LiteLLM에 접속할 URL (Anthropic 포맷 /v1/messages 제공).
ANTHROPIC_BASE_URL=http://localhost:4000
# Agent SDK 인증 토큰 = 외부 LiteLLM의 인증값. (잘 되는 Claude Code CLI는 "dummy" 사용)
ANTHROPIC_AUTH_TOKEN=dummy
# Agent SDK가 요청할 모델명 = 외부 LiteLLM의 model_name 과 "반드시 일치"해야 한다.
# (예: litellm config가 model_name: minimax-m2.5 이면 아래도 minimax-m2.5)
DEEPASSIST_MODEL=minimax-m2.5
# Claude Code의 small/fast(백그라운드) 모델도 같은 로컬 모델로. 비우면 DEEPASSIST_MODEL 사용.
DEEPASSIST_SMALL_MODEL=
# 로컬/오프라인 모델 필수: 비필수 트래픽(텔레메트리·자동업데이트·small모델) 차단. 기본 1.
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# ── 외부 vLLM (서빙 모델명 조회용, dev_agent_client 방식) ──
VLLM_BASE_URL=http://localhost:8080

# ── OpenAI 백엔드 (선택) ──
OPENAI_API_KEY=

# ── 에이전트 동작 ──
# default | acceptEdits | plan | bypassPermissions
DEEPASSIST_PERMISSION_MODE=acceptEdits
# 승인 게이트를 걸 도구(mcp 이름). 비우면 게이트 없음. 예: bash,write,edit
DEEPASSIST_APPROVAL_TOOLS=
# skills 로드: all | (콤마목록) | 빈값(=none)
DEEPASSIST_SKILLS=all
# 도구 위임 왕복 타임아웃(초) — heartbeat로 연장 가능.
DEEPASSIST_TOOL_TIMEOUT=300
DEEPASSIST_MAX_SESSIONS=200
DEEPASSIST_CORS_ORIGINS=*
# 문제 진단 시 DEBUG (SDK 메시지 타입·상세 로그 노출)
DEEPASSIST_LOG_LEVEL=INFO
# Agent SDK 서브프로세스 작업 디렉토리(서버측). 클라 워크스페이스 경로를 쓰지 않는다.
DEEPASSIST_AGENT_CWD=~/.deepassist/agent

# ── RAG (서버직접, 벡터 DB) ──
# 지식 벡터 DB 경로 (dev_agent_client와 동일 기본값). knowledge 도구가 이 DB를 검색한다.
KNOWLEDGE_BASE_DIR=~/.deepassist/knowledge
RERANKER_MODEL=~/.deepassist/models/reranker

# ── 외부 MCP 서버 등록 (선택) ── JSON dict, Agent SDK mcp_servers에 병합
#   stdio 예: {"mytools":{"command":"python","args":["mcp/server.py"]}}
#   http  예: {"github":{"type":"http","url":"https://api.githubcopilot.com/mcp/"}}
DEEPASSIST_MCP_SERVERS=
