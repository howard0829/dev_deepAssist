# ──────────────────────────────────────────────────────────────
# DeepAssist 서버 환경변수 (샘플)
#   cp .env.sample .env  후 값 조정.  start.sh가 이 파일을 로드한다.
# ──────────────────────────────────────────────────────────────

# ── 포트 (요구사항 고정값) ──
DEEPASSIST_PORT=8000        # DeepAssist WebSocket/HTTP 서버
LITELLM_PORT=4000           # LiteLLM 프록시 (Anthropic /v1/messages)

DEEPASSIST_HOST=0.0.0.0
LITELLM_HOST=127.0.0.1

# ── start.sh 구동 토글 ──
# vLLM은 외부(공유 서버)에서 이미 서빙 중이라고 가정 — start.sh는 시작하지 않는다.
# 이미 떠 있는 LiteLLM을 재사용하려면 false.
START_LITELLM=true

# ── LLM 연결 (Agent SDK → LiteLLM) ──
# Agent SDK는 이 base_url의 /v1/messages(Anthropic 포맷)로 요청한다.
# 비우면 http://LITELLM_HOST:LITELLM_PORT 로 자동 구성.
ANTHROPIC_BASE_URL=
# LiteLLM master key = Agent SDK가 보낼 인증 토큰.
LITELLM_MASTER_KEY=sk-deepassist-local
ANTHROPIC_AUTH_TOKEN=
# Agent SDK가 요청할 모델명 = LiteLLM config.yaml 의 model_name.
DEEPASSIST_MODEL=deepassist

# ── vLLM (외부에서 서빙 중) ──
# 서빙 모델명은 선언하지 않는다. 서버가 /v1/models로 서빙 중인 모델을 읽어 그대로
# 사용한다(dev_agent_client 방식, fetch_vllm_models). 아래는 그 조회에 쓸 base URL.
# (LiteLLM의 실제 라우팅 모델은 litellm/config.yaml 에서 관리)
VLLM_BASE_URL=http://localhost:8080

# ── OpenAI 백엔드 (선택) ──
OPENAI_API_KEY=

# ── 에이전트 동작 ──
# default | acceptEdits | plan | bypassPermissions
DEEPASSIST_PERMISSION_MODE=acceptEdits
# 승인 게이트를 걸 도구(mcp 이름). 비우면 게이트 없음. 예: bash,write,edit
DEEPASSIST_APPROVAL_TOOLS=
# skills 로드: all | (콤마목록) | 빈값(=none)
DEEPASSIST_SKILLS=all
# 도구 위임 왕복 타임아웃(초) — heartbeat로 연장 가능.
DEEPASSIST_TOOL_TIMEOUT=300
DEEPASSIST_MAX_SESSIONS=200
DEEPASSIST_CORS_ORIGINS=*

# ── RAG (선택, 기존 자산 재활용 시) ──
RERANKER_MODEL=~/.deepassist/models/reranker
